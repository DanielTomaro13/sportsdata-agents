# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# Env / secrets
.env
.env.*
!.env.example
*.local
secrets/

# Data / artifacts (root-anchored so they don't match the src/ package dirs
# `sportsdata_agents/data/` or `.../artifacts/`)
*.sqlite
*.db
/data/
/artifacts/
*.parquet
*.csv

# Tooling
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Node (web interface, later)
node_modules/
.next/
dist/

# OS / editor
.DS_Store
.idea/
.vscode/
.claude/

# stray run logs (the app writes to the OS logs dir; these are dev artifacts)
*.log

# Local runtime overrides (market dictionary, etc.) — never committed
*.local.json

# PyInstaller build spec (generated by scripts/build-desktop.sh)
/sportsdata.spec

# generated by setup-stripe.py (test/live Payment Link URLs) — regenerate, never commit
site/stripe.json
