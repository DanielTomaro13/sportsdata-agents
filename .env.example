# Copy to .env for local dev (never commit .env). All vars are prefixed SPORTSDATA_AGENTS_.

# Environment
SPORTSDATA_AGENTS_ENV=dev
SPORTSDATA_AGENTS_LOG_LEVEL=INFO

# Data layer (matches docker-compose.yml)
SPORTSDATA_AGENTS_DATABASE_URL=postgresql+asyncpg://agents:agents@localhost:5432/sportsdata_agents

# Default local tenant / workspace
SPORTSDATA_AGENTS_DEFAULT_TENANT=local
SPORTSDATA_AGENTS_DEFAULT_WORKSPACE=local

# Data plane — how to launch sportsdata-mcp (JSON list). Default: ["sportsdata-mcp"]
# SPORTSDATA_AGENTS_MCP_COMMAND=["uvx","--from","git+ssh://git@github.com/DanielTomaro13/sportsdata-mcp.git@v0.1.0","sportsdata-mcp"]

# Observability (D8)
# SPORTSDATA_AGENTS_LOGFIRE_TOKEN=...

# ── Secrets (env is always preferred over the in-config map) ──
# Your own LLM key for BYO-LLM local dev. ANY of these works — the live E2E test and
# the workspace tier-overrides are provider-agnostic. Gemini (Google AI Studio) and
# Groq have FREE tiers, so local dev + the live test can cost $0:
# ANTHROPIC_API_KEY=...
# GEMINI_API_KEY=...          # free tier: gemini/gemini-2.5-flash-lite
# GROQ_API_KEY=...            # free tier: groq/llama-3.3-70b-versatile
# OPENAI_API_KEY=...
# Premium data-provider keys passed through to the MCP subprocess:
# DATAGOLF_KEY=...

# ── Notifications: Slack and Discord are equals ────────────────────────────
# Slack: bot token + channel ids (alerts use the subscription's channel field)
# SLACK_BOT_TOKEN=xoxb-...
# OPS_SLACK_CHANNEL=C...            # weekly ops reports + escalations
# Discord: channel webhooks (Channel settings -> Integrations -> Webhooks);
# no bot needed for pushes. The chat adapter (`agents discord`) separately
# needs DISCORD_BOT_TOKEN.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...   # alert default
# OPS_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...   # ops reports + escalations
# DISCORD_BOT_TOKEN=...

# ── operator mode (the platform OWNER's deployment, not a customer install) ──
# Set this on YOUR machine/server only. It turns on the platform-maintenance jobs
# (eval_benchmark, site_manager, refresh_books, ops_health) and the self-healing
# incident_triage -> repo_improver handoff. Customer installs leave it unset and
# run only the data plane (ingest/monitor/custodian/resolve/results/steward).
# SPORTSDATA_OPERATOR=1
